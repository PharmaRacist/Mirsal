#!/usr/bin/env python3
import errno
import json
import os
import select
import subprocess
import sys

sys.path.insert(0, "/usr/lib/noon-mirsal")
import protocol

PALETTE_PATH = os.path.join(
    os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache")),
    "noon", "user", "generated", "colors", "firefox.json",
)
RELOAD_FLAG = os.path.join(
    os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache")),
    "noon", "mirsal", "reload.flag",
)

if len(sys.argv) > 1 and sys.argv[1] in {"pull-palette", "reload", "--help"}:
    arg = sys.argv[1]
    if arg == "--help":
        print("usage: mirsald [--help] <command>")
        print()
        print("commands:")
        print("  pull-palette    read firefox.json and print the palette")
        print("  reload          reload the mirsal browser extension")
        sys.exit(0)
    elif arg == "pull-palette":
        try:
            with open(PALETTE_PATH) as f:
                palette = json.load(f)
            print(json.dumps(palette, indent=2))
        except Exception as e:
            print(f"error: {e}", file=sys.stderr)
            sys.exit(1)
        sys.exit(0)
    elif arg == "reload":
        try:
            os.makedirs(os.path.dirname(RELOAD_FLAG), exist_ok=True)
            with open(RELOAD_FLAG, "w") as f:
                f.write("")
            print("reload flag set")
        except Exception as e:
            print(f"error: {e}", file=sys.stderr)
            sys.exit(1)
        sys.exit(0)


def _xdg_download_dir():
    try:
        with open(os.path.expanduser("~/.config/user-dirs.dirs")) as f:
            for line in f:
                line = line.strip()
                if line.startswith("XDG_DOWNLOAD_DIR="):
                    val = line.split("=", 1)[1].strip().strip('"').strip("'")
                    return val.replace("$HOME", os.path.expanduser("~"))
    except OSError:
        pass
    return os.path.expanduser("~/Downloads")


def consume_reload_flag():
    try:
        os.remove(RELOAD_FLAG)
        return True
    except OSError as e:
        if e.errno == errno.ENOENT:
            return False
        raise


def push_palette(reload=False):
    try:
        with open(PALETTE_PATH) as f:
            palette = json.load(f)
        mtime = os.path.getmtime(PALETTE_PATH)
        protocol.write({
            "type": "palette_colors",
            "payload": palette,
            "mtime": mtime,
            "reload": reload,
        })
    except Exception as e:
        protocol.write({"type": "palette_colors", "error": str(e)})


def ipc_call(method, payload):
    result = subprocess.run(
        ["noon", "ipc", "call", "mirsal", method, payload],
        capture_output=True,
    )
    return result.returncode == 0, result.stderr.decode().strip()


def feed_download(msg_type, data):
    ipc_call("feedDownloadInfo", json.dumps({"type": msg_type, "data": data}))


def handle_message(msg):
    t = msg.get("type", "")

    if t == "downloads.add":
        raw = msg.get("payload", "{}")
        try:
            p = json.loads(raw) if isinstance(raw, str) else raw
        except json.JSONDecodeError as e:
            protocol.write({"status": "error", "error": f"invalid payload json: {e}"})
            return
        filename = p.get("filename", "").split("/")[-1] or p.get("url", "").split("/")[-1] or "download"
        p["destination"] = os.path.join(_xdg_download_dir(), filename)
        feed_download("downloads.add", p)
        protocol.write({"status": "ok"})

    elif t == "downloads.changed":
        raw = msg.get("payload", "{}")
        try:
            p = json.loads(raw) if isinstance(raw, str) else raw
        except json.JSONDecodeError:
            return
        feed_download("downloads.changed", p)

    elif t == "downloads.erased":
        raw = msg.get("payload", "{}")
        try:
            p = json.loads(raw) if isinstance(raw, str) else raw
        except json.JSONDecodeError:
            return
        feed_download("downloads.erased", p)

    elif t == "bookmarks.sync":
        bookmarks = msg.get("payload", [])
        ok, err = ipc_call("feedBookmarks", json.dumps(json.dumps(bookmarks)))
        if not ok:
            protocol.write({"status": "error", "error": err})
        else:
            protocol.write({"status": "ok"})

    elif t == "watch":
        push_palette()


last_mtime = os.path.getmtime(PALETTE_PATH) if os.path.exists(PALETTE_PATH) else 0

r, _, _ = select.select([sys.stdin], [], [], 5.0)
if not r:
    push_palette()
else:
    handle_message(protocol.read())

while True:
    r, _, _ = select.select([sys.stdin], [], [], 0.5)
    if r:
        try:
            msg = protocol.read()
            if msg is None:
                break
            handle_message(msg)
        except EOFError:
            break

    reload = consume_reload_flag()
    try:
        mtime = os.path.getmtime(PALETTE_PATH)
    except Exception:
        mtime = last_mtime
    if reload or mtime != last_mtime:
        last_mtime = mtime
        push_palette(reload=reload)
